# ============================================================
# Agora ConvoAI Custom LLM Wrapper — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ----------------------------------------------------------
# Upstream LLM (OpenAI-compatible endpoint)
# ----------------------------------------------------------
# Change OPENAI_BASE_URL to use Azure OpenAI, Groq, Ollama, OpenRouter, etc.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ----------------------------------------------------------
# Agora (for RTM result delivery)
# ----------------------------------------------------------
# App ID from Agora Console → Project Management
AGORA_APP_ID=

# App Certificate from Agora Console → Project Management (keep secret)
AGORA_APP_CERTIFICATE=

# UID this wrapper uses when publishing RTM messages
AGORA_RTM_SENDER_UID=custom-llm-wrapper

# Customer ID + Secret for Agora REST API Basic Auth
# Get these from: Agora Console → Developer Toolkit → RESTful API
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=

# ----------------------------------------------------------
# Dify tool API keys (one per tool defined in tools.yaml)
# api_key_env in tools.yaml references these names.
# ----------------------------------------------------------
# DIFY_ORDER_API_KEY=app-...
# DIFY_KB_API_KEY=app-...
# DIFY_WEB_SEARCH_API_KEY=app-...
DIFY_WEATHER_API_KEY=app-...


# ----------------------------------------------------------
# App settings
# ----------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
TOOLS_CONFIG=config/tools.yaml
LOG_LEVEL=INFO
